# Sphera Brand — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3006

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sphera_brand
DB_USER=postgres
DB_PASSWORD=

# Auth
JWT_SECRET=

# Google Cloud / Vertex AI (obrigatório para IA)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json  # opcional se usar ADC

# Embedding model (padrão: text-embedding-004)
VERTEX_EMBEDDING_MODEL=text-embedding-004

# n8n Integration (opcional)
N8N_API_KEY=

# STORY-015: Instagram / Meta OAuth
# Crie em https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=
# URL pública do backend (necessário para o callback OAuth)
API_PUBLIC_URL=http://localhost:3001/api

# STORY-015: Criptografia AES-256-GCM para tokens OAuth sociais
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# OBRIGATÓRIO para STORY-015 (tokens OAuth do Instagram)
SOCIAL_TOKEN_ENCRYPTION_KEY=
