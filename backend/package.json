{
  "name": "backend",
  "version": "1.0.0",
  "description": "MVP Backend with Node.js, TypeScript and Express",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node db/migrate.ts",
    "migrate:branding": "ts-node db/migrate_branding_fix.ts",
    "migrate:calendarios": "ts-node db/migrate_calendarios_fix.ts",
    "migrate:contexto": "ts-node db/migrate_contexto_temporal.ts",
    "migrate:missing": "ts-node db/migrate_missing_cols.ts",
    "migrate:jobs": "ts-node db/migrate_calendar_jobs.ts",
    "migrate:prompt-templates": "ts-node db/migrate_prompt_templates.ts",
    "migrate:prompt-templates-v2": "ts-node db/migrate_prompt_templates_v2.ts",
    "seed:datas": "psql $POSTGRES_DB < db/seeds/datas_comemorativas.sql",
    "migrate:calendar-items": "ts-node db/migrate_calendar_items.ts",
    "migrate:creative": "ts-node db/migrate_creative_production.ts",
    "migrate:design-recipes": "ts-node db/migrate_design_recipes.ts",
    "migrate:template-master": "ts-node db/migrate_template_master_engine.ts",
    "migrate:prompt-agent": "ts-node db/migrate_prompt_agent.ts",
    "migrate:prompt-indices": "ts-node db/migrate_prompt_indices.ts",
    "migrate:clientes-agent": "ts-node db/migrate_clientes_agent_id.ts",
    "migrate:visual-design": "ts-node db/migrate_visual_design.ts",
    "migrate:job-retry": "ts-node db/migrate_job_retry_fields.ts",
    "migrate:post-approval": "ts-node db/migrate_post_approval.ts",
    "migrate:image-generation": "ts-node db/migrate_image_generation.ts",
    "migrate:all": "npm run migrate:branding && npm run migrate:calendarios && npm run migrate:contexto && npm run migrate:jobs && npm run migrate:prompt-templates && npm run migrate:prompt-templates-v2 && npm run migrate:calendar-items && npm run migrate:creative && npm run migrate:design-recipes && npm run migrate:template-master && npm run migrate:prompt-agent && npm run migrate:prompt-indices && npm run migrate:clientes-agent && npm run migrate:visual-design && npm run migrate:job-retry && npm run migrate:post-approval && npm run migrate:image-generation",
    "test:creative": "ts-node tests/test-creative-engine.ts",
    "test:design-recipe": "ts-node tests/test-design-recipe-engine.ts",
    "test:template-master": "ts-node tests/test-template-master-engine.ts",
    "test:template-master-flow": "ts-node tests/test-template-master-calendar-flow.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^2.0.0",
    "@google/generative-ai": "^0.21.0",
    "@resvg/resvg-js": "^2.6.2",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.16.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "puppeteer": "^24.31.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.6",
    "satori": "^0.26.0",
    "ssh2": "^1.17.0",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.10",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
